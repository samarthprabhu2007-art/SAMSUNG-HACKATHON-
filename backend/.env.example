# LLM Configuration
# Choose between: gemini, openai, ollama
LLM_PROVIDER=gemini

# Google Gemini API Keys
# Get keys from: https://aistudio.google.com/apikey
# Prefer GEMINI_API_KEYS for rotation. Keep GEMINI_API_KEY only for single-key fallback.
GEMINI_API_KEYS=key_one,key_two
GEMINI_API_KEY=key_one

# Groq Vision for Focus Monitor screen checks
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SCREEN_MONITOR_PROVIDER=groq
SCREEN_MONITOR_FALLBACK_TO_GEMINI=false

# OpenAI API Key (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Endpoint (if LLM_PROVIDER=ollama)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
# Server Configuration
# Port the backend server will run on (defaults to 3000 if not specified)
PORT=3000
